{
  "name": "deskrag-app",
  "version": "0.0.1",
  "description": "DeskRAGApp — desktop UI for DeskRAG local-first session memory",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --config electron-builder.yml",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 --module-dir ../"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.1.0"
  },
  "dependencies": {
    "lottie-web": "^5.13.0"
  }
}
